# ============================================================================
# Sphaire environment configuration — copy to .env.local and fill in.
# NEVER commit real secrets. (If you cloned this repo and saw real keys here in
# git history, rotate them immediately — they are considered compromised.)
# ============================================================================

# --- Core AI (OpenAI-compatible). Users can also bring their own key in the UI. ---
# Single key:
OPENAI_API_KEY=sk-your-key-here
# ...or a comma-separated pool for rate-limit rotation (optional):
# OPENAI_API_KEYS=sk-key-1,sk-key-2,sk-key-3

# --- Supabase (optional). Only needed for cloud saving + the shared RAG flywheel. ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Site ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Generative mesh (Tier-2 ④, optional). For organic/artistic prompts. ---
# Replicate token + an image-to-3D model version (TRELLIS / Hunyuan3D-2 / Stable Fast 3D).
# If unset, the app simply skips mesh generation and stays parametric.
# REPLICATE_API_TOKEN=r8_your-token
# MESH_GEN_MODEL=owner/model:version-hash
# MESH_GEN_INPUT_KEY=images   # input field name the model expects (default: images)
