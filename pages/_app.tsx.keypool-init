/**
 * Add this to your _app.tsx to initialize the API key pool
 * 
 * This enables load balancing across multiple OpenAI API keys
 * to bypass rate limits completely!
 */

import { useEffect } from 'react';
import { initializeKeyPool } from '../services/apiKeyPool';

// Add this inside your App component:

useEffect(() => {
  // Initialize API key pool on app start
  const apiKeysEnv = process.env.NEXT_PUBLIC_OPENAI_API_KEYS || process.env.OPENAI_API_KEYS;
  
  if (apiKeysEnv && apiKeysEnv.includes(',')) {
    // Multiple keys provided
    const keys = apiKeysEnv.split(',').map(k => k.trim()).filter(k => k.length > 0);
    
    if (keys.length > 1) {
      initializeKeyPool(keys);
      console.log(`✅ [APP] Initialized API key pool with ${keys.length} keys`);
      console.log(`🚀 [APP] Effective rate limit: ${keys.length}x normal limit!`);
    }
  } else {
    console.log('ℹ️ [APP] Using single API key (no pool)');
    console.log('💡 [APP] Add OPENAI_API_KEYS=key1,key2,key3 to .env.local for load balancing');
  }
}, []);
